# Certify / Emburse integration placeholder configuration
# Copy this file to a server-side secure location later, for example:
#   /etc/projecttime/certify.env
#
# Do NOT commit real API keys, client secrets, passwords, access tokens, or refresh tokens.
# Do NOT expose these values to React, localStorage, or browser-side JavaScript.

# Base URL provided by Certify / Emburse support.
CERTIFY_BASE_URL="https://placeholder.certify.example"

# Authentication mode expected from Certify / Emburse.
# Expected future values:
#   api_key
#   oauth_client_credentials
#   service_account
CERTIFY_AUTH_MODE="placeholder"

# API key mode placeholder.
CERTIFY_API_KEY="REPLACE_WITH_SECURE_SERVER_SIDE_SECRET"

# OAuth mode placeholders.
CERTIFY_CLIENT_ID="REPLACE_WITH_CLIENT_ID"
CERTIFY_CLIENT_SECRET="REPLACE_WITH_SECURE_SERVER_SIDE_SECRET"
CERTIFY_TOKEN_URL="https://placeholder.certify.example/oauth/token"
CERTIFY_SCOPE="expenses.read receipts.read users.read"

# Tenant/company identifier if Certify requires one.
CERTIFY_COMPANY_ID="REPLACE_WITH_COMPANY_OR_TENANT_ID"

# Sync behavior.
CERTIFY_SYNC_LOOKBACK_DAYS="45"
CERTIFY_SYNC_APPROVED_ONLY="true"
CERTIFY_SYNC_INCLUDE_RECEIPTS="true"

# Project/customer mapping fields.
# These values depend on how your Certify tenant stores project/customer references.
CERTIFY_PROJECT_CODE_FIELD="ProjectCode"
CERTIFY_CUSTOMER_FIELD="Customer"
CERTIFY_BILLABLE_FLAG_FIELD="Billable"
CERTIFY_COST_CENTER_FIELD="CostCenter"

# Safety mode.
# Keep true until real backend connector and staging review are ready.
CERTIFY_DRY_RUN_ONLY="true"
